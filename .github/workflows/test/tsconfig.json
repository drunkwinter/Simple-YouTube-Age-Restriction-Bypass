{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "rootDir": "./",
      "moduleResolution": "NodeNext",
      "baseUrl": "./",
      "sourceMap": true,
      "outDir": "./dist2",
      "noImplicitAny": true,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "strict": true,
      "skipLibCheck": true,
      "newLine": "lf"
    },
    "exclude": ["./dist2", "./node_modules", "./__tests__", "./coverage"]
  }
